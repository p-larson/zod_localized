<div class="card mb-2">
  <div class="card-body">
    <%= bootstrap_form_for @item do |f| %>
      <%= f.text_field :name, label: 'Name' %>

      <%= f.number_field :amount, label: 'Amount', step: 0.01 %>

      <%= f.number_field :maximum_amount, label: 'Maximum Amount', step: 0.01 %>

      <%= f.submit 'Save Item', class: 'btn btn-primary' %>
      <%= link_to "Cancel", items_path, class: "btn btn-danger" %>
    <% end %>
  </div>
</div>
